<idea-plugin>
    <id>com.laowang.idea.immersive</id>
    <name>Immersive Translate</name>
    <vendor email="laowang@example.com" url="https://github.com/laowang/idea-immersive-translate">Laowang</vendor>

    <description><![CDATA[
        <p>Immersive bilingual translation for code comments, Markdown, and plain text files.
        Supports OpenAI-compatible, Gemini, Microsoft Translator, and Google Cloud Translation providers with provider-scoped credentials.</p>
    ]]></description>

    <resource-bundle>messages.ImmersiveTranslateBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensionPoints>
        <extensionPoint
            qualifiedName="com.laowang.idea.immersive.translationEngine"
            interface="com.laowang.idea.immersive.engine.TranslationEngine"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.laowang.idea.immersive.textExtractor"
            interface="com.laowang.idea.immersive.extractor.TextExtractor"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.laowang.idea.immersive.translationRenderer"
            interface="com.laowang.idea.immersive.renderer.TranslationRenderer"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            id="com.laowang.idea.immersive.settings"
            displayName="Immersive Translate"
            instance="com.laowang.idea.immersive.settings.ImmersiveTranslateConfigurable"/>

        <applicationService
            serviceImplementation="com.laowang.idea.immersive.settings.ImmersiveTranslateSettings"/>
        <applicationService
            serviceImplementation="com.laowang.idea.immersive.settings.SettingsService"/>
        <applicationService
            serviceImplementation="com.laowang.idea.immersive.settings.CredentialsStore"/>
        <applicationService
            serviceImplementation="com.laowang.idea.immersive.cache.TranslationCache"/>
        <projectService
            serviceImplementation="com.laowang.idea.immersive.renderer.TranslationOverlayStore"/>
        <projectService
            serviceImplementation="com.laowang.idea.immersive.core.TranslationCoordinator"/>

        <notificationGroup
            id="ImmersiveTranslate"
            displayType="BALLOON"/>
    </extensions>

    <extensions defaultExtensionNs="com.laowang.idea.immersive">
        <translationEngine implementation="com.laowang.idea.immersive.engine.OpenAIEngine"/>
        <translationEngine implementation="com.laowang.idea.immersive.engine.GeminiEngine"/>
        <translationEngine implementation="com.laowang.idea.immersive.engine.MicrosoftTranslatorEngine"/>
        <translationEngine implementation="com.laowang.idea.immersive.engine.GoogleCloudTranslateEngine"/>
        <textExtractor implementation="com.laowang.idea.immersive.extractor.PsiCommentExtractor"/>
        <textExtractor implementation="com.laowang.idea.immersive.extractor.MarkdownBlockExtractor"/>
        <textExtractor implementation="com.laowang.idea.immersive.extractor.PlainTextBlockExtractor"/>
        <translationRenderer implementation="com.laowang.idea.immersive.renderer.inlay.InlayRenderer"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <action
            id="com.laowang.idea.immersive.ImmersiveTranslateAction"
            class="com.laowang.idea.immersive.trigger.ImmersiveTranslateAction"
            text="Immersive Translate"
            description="Translate source text in current editor">
            <keyboard-shortcut keymap="$default" first-keystroke="alt I"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="com.laowang.idea.immersive.ClearTranslationAction"
            class="com.laowang.idea.immersive.trigger.ClearTranslationAction"
            text="Clear Translations"
            description="Clear all translation inlays in current editor">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
